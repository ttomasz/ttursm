          ]],
          ["image", "capital"]
        ],
        "text-field": ["step", ["zoom"], "", 17, ["get", "name"]],
        "text-size": 11,
        "text-allow-overlap": false,
        "text-overlap": "never",
        "text-optional": true,
        "icon-offset": ["step", ["zoom"], ["literal", [0, 0]], 17, ["literal", [0, -17]]]
