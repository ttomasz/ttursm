            "optician",
            ["==", ["get", "shop"], "hairdresser"],
            "hairdresser",
            ["==", ["get", "shop"], "butcher"],
            "slaughterhouse",
            ["==", ["get", "shop"], "beauty"],
            "hairdresser",
            ["==", ["get", "shop"], "pawnbroker"],
            "bank",
            ["==", ["get", "shop"], "florist"],
            "florist",
            ["==", ["get", "shop"], "bakery"],
            "bakery",
            ["==", ["get", "shop"], "doityourself"],
            "paint",
            ["==", ["get", "shop"], "tattoo"],
            "hairdresser",
            ["==", ["get", "shop"], "tailor"],
            "hairdresser",
            ["==", ["get", "shop"], "travel_agency"],
            "car",
            ["==", ["get", "shop"], "furniture"],
            "furniture",
            ["==", ["get", "shop"], "dry_cleaning"],
            "laundry",
            ["==", ["get", "shop"], "laundry"],
            "laundry",
            ["==", ["get", "shop"], "bicycle"],
            "bicycle",
