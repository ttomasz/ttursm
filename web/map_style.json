{
  "version": 8,
  "name": "Ursus",
  "metadata": {},
  "center": [20.8828989, 52.1960985],
  "zoom": 15,
  "sources": {
    "parking": {
      "type": "geojson",
      "data": "https://ttomasz.github.io/ttursm/parking.geojson"
    },
    "parking_spaces": {
      "type": "geojson",
      "data": "https://ttomasz.github.io/ttursm/parking_spaces.geojson"
    },
    "shops_and_food": {
      "type": "geojson",
      "data": "https://ttomasz.github.io/ttursm/shops_and_food.geojson"
    },
    "osm": {
      "type": "raster",
      "tiles": ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
      "minzoom": 0,
      "maxzoom": 19,
      "scheme": "xyz",
      "tileSize": 256,
      "attribution": "Podkład mapowy i dane OpenStreetMap"
    }
  },
  "sprite": "https://ttomasz.github.io/ttursm/sprites/maki",
  "glyphs": "https://orangemug.github.io/font-glyphs/glyphs/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "osm_basemap",
      "type": "raster",
      "source": "osm",
      "layout": {"visibility": "visible"}
    },
    {
      "id": "parking_fill",
      "type": "fill",
      "source": "parking",
      "minzoom": 10,
      "layout": {"visibility": "visible"},
      "paint": {
        "fill-color": [
          "match",
          ["get", "access"],
          "customers", "rgba(245, 131, 255, 0.7)",
          "private", "rgba(64, 64, 64, 0.7)",
          "rgba(20, 100, 200, 0.7)"
        ],
        "fill-outline-color": [
          "match",
          ["get", "access"],
          "customers", "rgba(46, 0, 104, 1)",
          "private", "rgba(0, 0, 0, 1)",
          "rgba(0, 0, 250, 1)"
        ]
      }
    },
    {
      "id": "parking_spaces_fill",
      "type": "fill",
      "source": "parking_spaces",
      "minzoom": 16,
      "layout": {"visibility": "visible"},
      "paint": {
        "fill-color": "rgba(0, 0, 0, 0)",
        "fill-opacity": 1,
        "fill-outline-color": "rgba(0, 0, 0, 1)"
      }
    },
    {
      "id": "shop_areas",
      "type": "fill",
      "source": "shops_and_food",
      "minzoom": 15,
      "layout": {"visibility": "visible"},
      "paint": {
        "fill-color": "rgba(0, 0, 0, 0)",
        "fill-opacity": 1,
        "fill-outline-color": "rgba(0, 0, 0, 1)"
      }
    },
    {
      "id": "parking_label",
      "type": "symbol",
      "source": "parking",
      "minzoom": 17,
      "layout": {
        "icon-image": ["image", "parking"],
        "icon-offset": [
          "case",
          ["==", ["coalesce", ["get", "capacity"], ""], ""],
          ["literal", [0, 0]],
          ["any", ["==", ["coalesce", ["get", "capacity:disabled"], ""], ""], ["==", ["coalesce", ["to-number", ["get", "capacity:disabled"]], 0], 0]],
          ["literal", [0, -17]],
          ["literal", [0, -30]]
        ],
        "text-field": [
          "case",
          ["==", ["coalesce", ["get", "capacity"], ""], ""],
          "",
          [
            "concat",
            "Liczba miejsc: ",
            ["get", "capacity"],
            [
              "case",
              ["any", ["==", ["coalesce", ["get", "capacity:disabled"], ""], ""], ["==", ["coalesce", ["to-number", ["get", "capacity:disabled"]], 0], 0]],
              "",
              ["concat", "\n dla niepełnosprawnych: ", ["get", "capacity:disabled"]]
            ]
          ]
        ],
        "text-size": 11,
        "icon-allow-overlap": true,
        "icon-overlap": "cooperative",
        "symbol-z-order": "auto",
        "text-allow-overlap": false,
        "text-overlap": "never",
        "text-ignore-placement": false,
        "text-optional": true,
        "symbol-sort-key": ["coalesce", ["to-number", ["get", "capacity"]], 0]
      },
      "paint": {
        "text-halo-color": "rgba(255, 255, 255, 1)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "shops_and_food_symbols",
      "type": "symbol",
      "source": "shops_and_food",
      "minzoom": 14,
      "filter": ["!=", ["get", "shop"], "vacant"],
      "layout": {
        "icon-size": ["step", ["zoom"], 1, 16, 1.3, 17, 1.5, 18, 2],
        "icon-allow-overlap": true,
        "icon-overlap": "cooperative",
        "symbol-z-order": "auto",
        "icon-image": [
          "coalesce",
          ["image", [
            "case",
            ["==", ["get", "amenity"], "cafe"],
            "cafe",
            ["==", ["get", "amenity"], "bar"],
            "bar",
